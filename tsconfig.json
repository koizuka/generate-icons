{
	"include": ["src/**/*.ts", "test/**/*.ts"],
	"exclude": ["node_modules", "**/*.test.ts"],
	"compilerOptions": {
		"target": "ES2022",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"outDir": "./dist",
		"rootDir": "./src",
		"types": ["vitest/globals"],
		"strict": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true
	}
}
